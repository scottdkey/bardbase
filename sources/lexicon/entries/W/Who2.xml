s">Merch. I, 2, 25</bibl></cit>. <bibl n="shak. mv 4.1.290" default="NO" valid="yes">IV, 1, 290</bibl>. <bibl n="shak. 2h4 1.1.28" default="NO" valid="yes">H4B I, 1, 28</bibl>. Ff <emph>who,</emph> Qq <cit><quote>whom:</quote> <bibl n="shak. r3 1.3.327" default="NO" valid="yes">R3 I, 3, 327</bibl></cit>. <bibl n="shak. r3 4.3.4" default="NO" valid="yes">IV, 3, 4</bibl>. F<hi rend="sub">1</hi> <emph>who,</emph> later Ff <cit><quote>whom:</quote> <bibl n="shak. err 5.137" default="NO" valid="yes">Err. V, 137</bibl></cit>. <bibl n="shak. lll 1.1.167" default="NO" valid="yes">LLL I, 1, 167</bibl>. <bibl n="shak. ayl 3.4.52" default="NO" valid="yes">As III, 4, 52</bibl>. <bibl n="shak. wt 2.2.6" default="NO" valid="yes">Wint. II, 2, 6</bibl>. <bibl n="shak. wt 4.4.510" default="NO" valid="yes">IV, 4, 510</bibl>. <bibl n="shak. 2h6 5.1.63" default="NO" valid="yes">H6B V, 1, 63</bibl>. <emph>whom</emph> for <emph>who</emph>: <cit><quote>whom, with Sebastian, . . . would here have killed your king,</quote> <bibl n="shak. tmp 5.76" default="NO" valid="yes">Tp. V, 76</bibl></cit> (later Ff and M. Edd. <emph>who</emph>). <cit><quote>whom, I thank heaven, is an honest woman,</quote> <bibl n="shak. mm 2.1.72" default="NO" valid="yes">Meas. II, 1, 72</bibl></cit> (Elbow's speech). <cit><quote>than whom no mortal so magnificent,</quote> <bibl n="shak. lll 3.180" default="NO" valid="yes">LLL III, 180</bibl></cit>. cf. <cit><quote>whom they say is killed to-night,</quote> <bibl n="shak. jn 4.2.165" default="NO" valid="yes">John IV, 2, 165</bibl></cit>. <cit><quote>whom in constancy you think stands so safe,</quote> <bibl n="shak. cym 1.4.137" default="NO" valid="yes">Cymb. I, 4, 137</bibl></cit>.<lb />Never adjectively joined to nouns, and always referring to nouns, never to sentences. Referring to persons, f. i. <bibl n="shak. ven 33" default="NO" valid="yes">Ven. 33</bibl>. <bibl n="shak. ven 33" default="NO" valid="yes">Ven. 33</bibl> <bibl n="shak. tmp 1.2.17" default="NO" valid="yes">Tp. I, 2, 17</bibl>. <bibl n="shak. tmp 1.2.17" default="NO" valid="yes">Tp. I, 2, 17</bibl> <bibl n="shak. tmp 1.2.17" default="NO" valid="yes">Tp. I, 2, 17</bibl> <bibl n="shak. tmp 1.2.17" default="NO" valid="yes">Tp. I, 2, 17</bibl> <bibl n="shak. tgv 2.7.3" default="NO" valid="yes">Gent. II, 7, 3</bibl>. <bibl n="shak. tgv 3.1.14" default="NO" valid="yes">III, 1, 14</bibl>. <bibl n="shak. tgv 3.1.14" default="NO" valid="yes">III, 1, 14</bibl> <bibl n="shak. tgv 3.2.37" default="NO" valid="yes">III, 2, 37</bibl>. <bibl n="shak. tgv 4.3.17" default="NO" valid="yes">IV, 3, 17</bibl>. To things or animals (cf. <emph>as who should say</emph> in <emph>Shall</emph>): <bibl n="shak. ven 87" default="NO" valid="yes">Ven. 87</bibl>. <bibl n="shak. ven 87" default="NO" valid="yes">Ven. 87</bibl> <bibl n="shak. ven 87" default="NO" valid="yes">Ven. 87</bibl> <bibl n="shak. ven 87" default="NO" valid="yes">Ven. 87</bibl> <bibl n="shak. ven 87" default="NO" valid="yes">Ven. 87</bibl> <bibl n="shak. ven 87" default="NO" valid="yes">Ven. 87</bibl> <bibl n="shak. ven 87" default="NO" valid="yes">Ven. 87</bibl> <bibl n="shak. ven 87" default="NO" valid="yes">Ven. 87</bibl> <bibl n="shak. ven 87" default="NO" valid="yes">Ven. 87</bibl> <bibl n="shak. luc 296" default="NO" valid="yes">Lucr. 296</bibl>. <bibl n="shak. luc 296" default="NO" valid="yes">Lucr. 296</bibl> <bibl n="shak. luc 296" default="NO" valid="yes">Lucr. 296</bibl> <bibl n="shak. luc 296" default="NO" valid="yes">Lucr. 296</bibl> <bibl n="shak. luc 296" default="NO" valid="yes">Lucr. 296</bibl> <bibl n="shak. luc 296" default="NO" valid="yes">Lucr. 296</bibl> <bibl n="shak. luc 296" default="NO" valid="yes">Lucr. 296</bibl> <bibl n="shak. luc 296" default="NO" valid="yes">Lucr. 296</bibl> <bibl n="shak. luc 296" default="NO" valid="yes">Lucr. 296</bibl> <bibl n="shak. luc 296" default="NO" valid="yes">Lucr. 296</bibl> <bibl n="shak. son 41.11" default="NO" valid="yes">Sonn. 41, 11</bibl>. <bibl n="shak. tgv