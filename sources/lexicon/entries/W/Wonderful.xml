<TEI.2><text><body><div1 type="alphabetic letter" n="W" org="uniform" sample="complete"><entryFree key="Wonderful" type="main" opt="n"><orth extent="full" opt="n">Wonderful,</orth> surprising, marvellous: <bibl n="shak. wiv 2.2.62" default="NO" valid="yes">Wiv. II, 2, 62</bibl>. <bibl n="shak. wiv 3.1.39" default="NO" valid="yes">III, 1, 39</bibl>. <bibl n="shak. ado 2.3.98" default="NO" valid="yes">Ado II, 3, 98</bibl> (followed by <emph>should</emph>). <bibl n="shak. ayl 3.2.201" default="NO" valid="yes">As III, 2, 201</bibl>. <bibl n="shak. shr 4.2.15" default="NO" valid="yes">Shr. IV, 2, 15</bibl>. <bibl n="shak. tn 3.4.290" default="NO" valid="yes">Tw. III, 4, 290</bibl>. <bibl n="shak. tn 5.232.290" default="NO" valid="yes">V, 232</bibl>. <bibl n="shak. jn 3.4.178" default="NO" valid="yes">John III, 4, 178</bibl>. <bibl n="shak. 2h4 5.1.72" default="NO" valid="yes">H4B V, 1, 72</bibl>. <bibl n="shak. h5 3.6.83" default="NO" valid="yes">H5 III, 6, 83</bibl>. <bibl n="shak. h5 4.8.117" default="NO" valid="yes">IV, 8, 117</bibl>. <bibl n="shak. r3 1.2.73" default="NO" valid="yes">R3 I, 2, 73</bibl>. <bibl n="shak. r3 1.2.73" default="NO" valid="yes">R3 I, 2, 73</bibl> <bibl n="shak. r3 3.1.135" default="NO" valid="yes">III, 1, 135</bibl>. <bibl n="shak. jc 1.3.14" default="NO" valid="yes">Caes. I, 3, 14</bibl>. <bibl n="shak. ham 1.5.118" default="NO" valid="yes">Hml. I, 5, 118</bibl>. <bibl n="shak. ham 3.2.340" default="NO" valid="yes">III, 2, 340</bibl>. <bibl n="shak. ant 1.2.159" default="NO" valid="yes">Ant. I, 2, 159</bibl>.<lb />Adverbially: <cit><quote>w. froward,</quote> <bibl n="shak. shr 1.1.69" default="NO" valid="yes">Shr. I, 1, 69</bibl></cit>. <cit><quote>a w. sweet air,</quote> <bibl n="shak. cym 2.3.19" default="NO" valid="yes">Cymb. II, 3, 19</bibl></cit>. cf. <bibl n="shak. ayl 3.2.201" default="NO" valid="yes">As III, 2, 201</bibl>.
