<TEI.2><text><body><div1 type="alphabetic letter" n="R" org="uniform" sample="complete"><entryFree key="Ruffian1" type="main" opt="n"><orth extent="full" opt="n">Ruffian,</orth> a brutal, boisterous, mischievous fellow: <bibl n="shak. ven 1149" default="NO" valid="yes">Ven. 1149</bibl>. <bibl n="shak. tgv 5.4.60" default="NO" valid="yes">Gent. V, 4, 60</bibl>. <bibl n="shak. ado 4.1.92" default="NO" valid="yes">Ado IV, 1, 92</bibl>. <bibl n="shak. shr 2.290" default="NO" valid="yes">Shr. II, 290</bibl>. <bibl n="shak. tn 4.1.60" default="NO" valid="yes">Tw. IV, 1, 60</bibl>. <bibl n="shak. jn 3.1.200" default="NO" valid="yes">John III, 1, 200</bibl>. <bibl n="shak. r2 2.4.12" default="NO" valid="yes">R2 II, 4, 12</bibl>. <bibl n="shak. 1h4 2.4.500" default="NO" valid="yes">H4A II, 4, 500</bibl>. <bibl n="shak. 2h4 4.5.125" default="NO" valid="yes">H4B IV, 5, 125</bibl>. <bibl n="shak. 2h6 1.1.188" default="NO" valid="yes">H6B I, 1, 188</bibl>. <bibl n="shak. 2h6 5.1.164" default="NO" valid="yes">V, 1, 164</bibl>. <bibl n="shak. tro 1.3.38" default="NO" valid="yes">Troil. I, 3, 38</bibl>. <bibl n="shak. tim 4.3.160" default="NO" valid="yes">Tim. IV, 3, 160</bibl>. <bibl n="shak. lr 2.2.67" default="NO" valid="yes">Lr. II, 2, 67</bibl>. <bibl n="shak. oth 1.1.111" default="NO" valid="yes">Oth. I, 1, 111</bibl>. <bibl n="shak. ant 4.1.4" default="NO" valid="yes">Ant. IV, 1, 4</bibl>.<lb />Adjectively: <cit><quote>r. lust,</quote> <bibl n="shak. err 2.2.135" default="NO" valid="yes">Err. II, 2, 135</bibl></cit>. <cit><quote>the r. billows,</quote> <bibl n="shak. 2h4 3.1.22" default="NO" valid="yes">H4B III, 1, 22</bibl></cit>. <cit><quote>to die in r. battle,</quote> <bibl n="shak. 2h6 5.2.49" default="NO" valid="yes">H6B V, 2, 49</bibl></cit>.
