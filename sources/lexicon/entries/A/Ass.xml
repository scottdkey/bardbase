valid="yes">5, 25</bibl> <bibl n="shak. tgv 5.2.28" default="NO" valid="yes">V, 2, 28</bibl>. <bibl n="shak. wiv 1.1.176" default="NO" valid="yes">Wiv. I, 1, 176</bibl>. <bibl n="shak. mm 2.2.315" default="NO" valid="yes">Meas. II, 2, 315</bibl>. <bibl n="shak. mm 5.506.315" default="NO" valid="yes">V, 506</bibl>. <bibl n="shak. err 2.1.14" default="NO" valid="yes">Err. II, 1, 14</bibl>. <bibl n="shak. err 2.2.201" default="NO" valid="yes">2, 201</bibl>. <bibl n="shak. err 3.1.15" default="NO" valid="yes">III, 1, 15</bibl>. <bibl n="shak. mnd 4.1.27" default="NO" valid="yes">Mids. IV, 1, 27</bibl>. <bibl n="shak. mnd 5.317.27" default="NO" valid="yes">V, 317</bibl> (quibble with <emph>ace</emph>). <bibl n="shak. ado 4.2.75" default="NO" valid="yes">Ado IV, 2, 75</bibl>. <bibl n="shak. ado 5.1.315" default="NO" valid="yes">V, 1, 315</bibl>. <bibl n="shak. lll 5.2.628" default="NO" valid="yes">LLL V, 2, 628</bibl> etc. etc.
