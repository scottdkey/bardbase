ibl n="shak. jn 5.7.112" default="NO" valid="yes">V, 7, 112</bibl>. <bibl n="shak. jn 5.7.112" default="NO" valid="yes">V, 7, 112</bibl> <bibl n="shak. r2 2.1.65" default="NO" valid="yes">R2 II, 1, 65</bibl>. <bibl n="shak. h5 2.4.9" default="NO" valid="yes">H5 II, 4, 9</bibl>.<lb />2) the king of England: <bibl n="shak. jn 2.56" default="NO" valid="yes">John II, 56</bibl>. <bibl n="shak. jn 2.56" default="NO" valid="yes">John II, 56</bibl> <bibl n="shak. jn 2.56" default="NO" valid="yes">John II, 56</bibl> <bibl n="shak. jn 3.4.8" default="NO" valid="yes">III, 4, 8</bibl> <cit><quote>(bloody E. into E. gone).</quote> <bibl n="shak. h5 3.5.48" default="NO" valid="yes">H5 III, 5, 48</bibl></cit> <cit><quote>(Harry E.).</quote> <bibl n="shak. h5 3.6.131" default="NO" valid="yes">III, 6, 131</bibl></cit>. <bibl n="shak. h5 5.2.12" default="NO" valid="yes">V, 2, 12</bibl> etc. <bibl n="shak. mac 4.3.43" default="NO" valid="yes">Mcb. IV, 3, 43</bibl>. <bibl n="shak. mac 4.3.43" default="NO" valid="yes">Mcb. IV, 3, 43</bibl>
