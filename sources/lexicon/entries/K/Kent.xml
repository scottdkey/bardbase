<TEI.2><text><body><div1 type="alphabetic letter" n="K" org="uniform" sample="complete"><entryFree key="Kent" type="main" opt="n"><orth extent="full" opt="n">Kent,</orth> 1) English county: <bibl n="shak. jn 4.2.200" default="NO" valid="yes">John IV, 2, 200</bibl>. <bibl n="shak. jn 5.1.30" default="NO" valid="yes">V, 1, 30</bibl>. <bibl n="shak. 1h4 2.1.60" default="NO" valid="yes">H4A II, 1, 60</bibl>. <bibl n="shak. 2h6 4.1.100" default="NO" valid="yes">H6B IV, 1, 100</bibl>. <bibl n="shak. 2h6 4.2.130" default="NO" valid="yes">IV, 2, 130</bibl>. <bibl n="shak. 2h6 4.7.59" default="NO" valid="yes">IV, 7, 59</bibl>. <bibl n="shak. 2h6 4.7.59" default="NO" valid="yes">IV, 7, 59</bibl> 65 <cit><quote>(K. in the Commentaries Caesar writ is termed the civil'st place of all this isle).</quote> <bibl n="shak. 2h6 4.10.46" default="NO" valid="yes">IV, 10, 46</bibl></cit>. <bibl n="shak. 2h6 4.10.46" default="NO" valid="yes">IV, 10, 46</bibl> <bibl n="shak. 2h6 5.1.75" default="NO" valid="yes">V, 1, 75</bibl>. <bibl n="shak. 3h6 1.1.156" default="NO" valid="yes">H6C I, 1, 156</bibl>. <bibl n="shak. 3h6 4.8.12" default="NO" valid="yes">IV, 8, 12</bibl>. <bibl n="shak. r3 4.4.505" default="NO" valid="yes">R3 IV, 4, 505</bibl>.<lb />2) Earl of Kent: <bibl n="shak. r2 5.6.8" default="NO" valid="yes">R2 V, 6, 8</bibl>. <bibl n="shak. lr 1.1.27" default="NO" valid="yes">Lr. I, 1, 27</bibl> and passim.
