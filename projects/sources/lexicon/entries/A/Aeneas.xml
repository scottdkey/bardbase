<TEI.2><text><body><div1 type="alphabetic letter" n="A" org="uniform" sample="complete"><entryFree key="Aeneas" type="main" opt="n"><orth extent="full" opt="n">Aeneas,</orth> the Trojan hero: <bibl n="shak. tmp 2.1" default="NO" valid="yes">Tp. II, 1, 79</bibl>. <bibl n="shak. 2h6 5.2" default="NO" valid="yes">H6B V, 2, 62</bibl>. <bibl n="shak. tro 1.1.111" default="NO" valid="yes">Troil. I, 1, 111</bibl>. <bibl n="shak. tro 4.1.2" default="NO" valid="yes">IV, 1, 2</bibl> (and passim). <bibl n="shak. tit 3.2.27" default="NO" valid="yes">Tit. III, 2, 27</bibl>. <bibl n="shak. jc 1.2.112" default="NO" valid="yes">Caes. I, 2, 112</bibl>. <bibl n="shak. ham 2.2" default="NO" valid="yes">Hml. II, 2, 468</bibl>. <bibl n="shak. ant 4.14" default="NO" valid="yes">Ant. IV, 14, 53</bibl>. <bibl n="shak. cym 3.4" default="NO" valid="yes">Cymb. III, 4, 60</bibl>. Alluded to in <bibl n="shak. tit 2.3.22" default="NO" valid="yes">Tit. II, 3, 22</bibl> and <bibl n="shak. tit 5.3.80" default="NO" valid="yes">V, 3, 80</bibl>.
</entryFree></div1></body></text></TEI.2>