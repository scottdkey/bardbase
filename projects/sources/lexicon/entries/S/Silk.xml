<TEI.2><text><body><div1 type="alphabetic letter" n="S" org="uniform" sample="complete"><entryFree key="Silk" type="main" opt="n"><orth extent="full" opt="n">Silk,</orth> cloth made of the thread of Bombyx mori: <bibl n="shak. lc 48" default="NO" valid="yes">Compl. 48</bibl>. <bibl n="shak. wiv 2.2.68" default="NO" valid="yes">Wiv. II, 2, 68</bibl>. <bibl n="shak. wiv 4.4.73" default="NO" valid="yes">IV, 4, 73</bibl>. <bibl n="shak. lll 3.150" default="NO" valid="yes">LLL III, 150</bibl>. <bibl n="shak. mnd 5.348" default="NO" valid="yes">Mids. V, 348</bibl>. <bibl n="shak. wt 4.4.325" default="NO" valid="yes">Wint. IV, 4, 325</bibl>. <bibl n="shak. 2h4 1.2.222" default="NO" valid="yes">H4B I, 2, 222</bibl>. <bibl n="shak. tro 5.1.35" default="NO" valid="yes">Troil. V, 1, 35</bibl>. <bibl n="shak. cor 1.9.45" default="NO" valid="yes">Cor. I, 9, 45</bibl>. <bibl n="shak. cor 5.6.96" default="NO" valid="yes">V, 6, 96</bibl>. <bibl n="shak. tim 4.3.206" default="NO" valid="yes">Tim. IV, 3, 206</bibl>. <bibl n="shak. lr 3.4.108" default="NO" valid="yes">Lr. III, 4, 108</bibl>. <bibl n="shak. oth 3.4.73" default="NO" valid="yes">Oth. III, 4, 73</bibl>. <bibl n="shak. cym 2.4.69" default="NO" valid="yes">Cymb. II, 4, 69</bibl>. <bibl n="shak. cym 3.3.24" default="NO" valid="yes">III, 3, 24</bibl>. Per. <bibl n="shak. cym 4.0." default="NO" valid="yes">IV Prol. 21</bibl>. <bibl n="shak. cym 5.0." default="NO" valid="yes">V Prol. 8</bibl>. Plur. <cit><quote>--s:</quote> <bibl n="shak. err 4.3.8" default="NO" valid="yes">Err. IV, 3, 8</bibl></cit>. <bibl n="shak. mv 1.1.34" default="NO" valid="yes">Merch. I, 1, 34</bibl>. <bibl n="shak. tro 2.2.69" default="NO" valid="yes">Troil. II, 2, 69</bibl>. <bibl n="shak. lr 3.4.98" default="NO" valid="yes">Lr. III, 4, 98</bibl>. Adjectively: <cit><quote>s. hair,</quote> <bibl n="shak. ayl 3.5.46" default="NO" valid="yes">As III, 5, 46</bibl></cit>. <cit><quote>s. stockings,</quote> <bibl n="shak. 2h4 2.2.17" default="NO" valid="yes">H4B II, 2, 17</bibl></cit>. <cit><quote>s. thread,</quote> <bibl n="shak. rom 2.2.181" default="NO" valid="yes">Rom. II, 2, 181</bibl></cit>. <cit><quote>a s. button,</quote> <bibl n="shak. rom 2.4.24" default="NO" valid="yes">II, 4, 24</bibl></cit>.
