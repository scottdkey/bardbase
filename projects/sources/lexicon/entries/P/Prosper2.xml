<TEI.2><text><body><div1 type="alphabetic letter" n="P" org="uniform" sample="complete"><entryFree key="Prosper2" type="main" opt="n"><orth extent="full" opt="n">Prosper,</orth> vb. 1) tr. to render successful, to make happy: <bibl n="shak. wiv 3.1.30" default="NO" valid="yes">Wiv. III, 1, 30</bibl>. <bibl n="shak. wiv 5.2.14" default="NO" valid="yes">V, 2, 14</bibl>. <bibl n="shak. mnd 1.1.172" default="NO" valid="yes">Mids. I, 1, 172</bibl>. <bibl n="shak. 2h4 3.2.313" default="NO" valid="yes">H4B III, 2, 313</bibl>. <bibl n="shak. 1h6 1.1.53" default="NO" valid="yes">H6A I, 1, 53</bibl>. <bibl n="shak. 1h6 4.2.56" default="NO" valid="yes">IV, 2, 56</bibl>. <bibl n="shak. lr 3.7.92" default="NO" valid="yes">Lr. III, 7, 92</bibl>. <bibl n="shak. lr 4.6.30" default="NO" valid="yes">IV, 6, 30</bibl>.<lb />2) intr. to succeed, to thrive, to be fortunate: <bibl n="shak. tmp 2.1.72" default="NO" valid="yes">Tp. II, 1, 72</bibl>. <bibl n="shak. wiv 4.5.103" default="NO" valid="yes">Wiv. IV, 5, 103</bibl>. <bibl n="shak. mv 3.2.189" default="NO" valid="yes">Merch. III, 2, 189</bibl>. <bibl n="shak. tn 1.4.38" default="NO" valid="yes">Tw. I, 4, 38</bibl>. <bibl n="shak. wt 4.3.126" default="NO" valid="yes">Wint. IV, 3, 126</bibl>. <bibl n="shak. wt 4.4.70" default="NO" valid="yes">IV, 4, 70</bibl>. <bibl n="shak. r2 5.3.84" default="NO" valid="yes">R2 V, 3, 84</bibl>. <bibl n="shak. 1h6 5.5.106" default="NO" valid="yes">H6A V, 5, 106</bibl>. <bibl n="shak. 3h6 2.5.18" default="NO" valid="yes">H6C II, 5, 18</bibl>. <bibl n="shak. r3 2.1.16" default="NO" valid="yes">R3 II, 1, 16</bibl>. <bibl n="shak. r3 4.4.397" default="NO" valid="yes">IV, 4, 397</bibl>. <bibl n="shak. h8 1.2.169" default="NO" valid="yes">H8 I, 2, 169</bibl>. <bibl n="shak. lr 1.1.285" default="NO" valid="yes">Lr. I, 1, 285</bibl>. <bibl n="shak. lr 1.2.21" default="NO" valid="yes">I, 2, 21</bibl>. <bibl n="shak. per 4.2.13" default="NO" valid="yes">Per. IV, 2, 13</bibl>.
