<lb />3) a repast, entertainment, banquet <bibl n="shak. ven 447" default="NO" valid="yes">Ven. 447</bibl>. <bibl n="shak. ven 447" default="NO" valid="yes">Ven. 447</bibl> <bibl n="shak. son 141.8" default="NO" valid="yes">Sonn. 141, 8</bibl>. <bibl n="shak. lc 181" default="NO" valid="yes">Compl. 181</bibl>. <bibl n="shak. mm 1.2.57" default="NO" valid="yes">Meas. I, 2, 57</bibl> (<emph>impiety has made a f. of thee</emph>). <bibl n="shak. err 3.1.26" default="NO" valid="yes">Err. III, 1, 26</bibl>. <bibl n="shak. err 5.405.26" default="NO" valid="yes">V, 405</bibl>. <bibl n="shak. err 5.405.26" default="NO" valid="yes">V, 405</bibl> <bibl n="shak. ado 5.1.154" default="NO" valid="yes">Ado V, 1, 154</bibl>. <bibl n="shak. lll 5.1.40" default="NO" valid="yes">LLL V, 1, 40</bibl>. <bibl n="shak. mv 2.6.8" default="NO" valid="yes">Merch. II, 6, 8</bibl>. <bibl n="shak. mv 2.6.8" default="NO" valid="yes">Merch. II, 6, 8</bibl> <bibl n="shak. ayl 2.7.115" default="NO" valid="yes">As II, 7, 115</bibl>. <bibl n="shak. ayl 2.7.115" default="NO" valid="yes">As II, 7, 115</bibl> <bibl n="shak. wt 1.2.344" default="NO" valid="yes">Wint. I, 2, 344</bibl>. <bibl n="shak. wt 4.3.43" default="NO" valid="yes">IV, 3, 43</bibl>. <bibl n="shak. r2 1.3.67" default="NO" valid="yes">R2 I, 3, 67</bibl>. <bibl n="shak. r2 1.3.67" default="NO" valid="yes">R2 I, 3, 67</bibl> <bibl n="shak. 1h4 4.2.85" default="NO" valid="yes">H4A IV, 2, 85</bibl>. <bibl n="shak. 2h4 4.4.106" default="NO" valid="yes">H4B IV, 4, 106</bibl>. <bibl n="shak. 1h6 4.5.7" default="NO" valid="yes">H6A IV, 5, 7</bibl>. <bibl n="shak. tro 1.3.191" default="NO" valid="yes">Troil. I, 3, 191</bibl>. <bibl n="shak. rom 1.2.20" default="NO" valid="yes">Rom. I, 2, 20</bibl>. <bibl n="shak. rom 4.5.87" default="NO" valid="yes">IV, 5, 87</bibl> <emph>(a burial f.</emph>). <bibl n="shak. tim 1.1.270" default="NO" valid="yes">Tim. I, 1, 270</bibl>. <bibl n="shak. tim 1.2.62" default="NO" valid="yes">I, 2, 62</bibl>. <bibl n="s